# ─── Claude AI ────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
CLAUDE_MODEL=claude-opus-4-7

# ─── Google Ads API ────────────────────────────────────────────────────────────
# Obtenha em: https://developers.google.com/google-ads/api/docs/get-started/introduction
GOOGLE_ADS_DEVELOPER_TOKEN=seu_developer_token
GOOGLE_ADS_CLIENT_ID=seu_client_id.apps.googleusercontent.com
GOOGLE_ADS_CLIENT_SECRET=seu_client_secret
GOOGLE_ADS_REFRESH_TOKEN=seu_refresh_token
GOOGLE_ADS_LOGIN_CUSTOMER_ID=1234567890        # MCC ID (sem hífens)
GOOGLE_ADS_CUSTOMER_IDS=1234567890,9876543210  # Contas a otimizar (CSV)

# ─── Meta Ads API ──────────────────────────────────────────────────────────────
# Obtenha em: https://developers.facebook.com/docs/marketing-apis/get-started
META_ACCESS_TOKEN=EAAxxxxx...
META_AD_ACCOUNT_IDS=act_123456789,act_987654321  # Contas a otimizar (CSV)

# ─── WhatsApp (Evolution API) ─────────────────────────────────────────────────
EVOLUTION_API_URL=https://evo.seudominio.com.br   # URL base da sua Evolution API
EVOLUTION_API_KEY=sua_api_key                      # apikey da instância
EVOLUTION_INSTANCE=impulsionanumber3               # nome da instância
EVOLUTION_GROUP_JID=120363423820098780@g.us        # JID do grupo de notificações

# ─── API de segurança ──────────────────────────────────────────────────────────
API_SECRET=troque-esta-chave-por-algo-seguro-e-longo

# ─── Guardrails de segurança ───────────────────────────────────────────────────
MAX_BID_CHANGE_PCT=0.20        # Máximo 20% de variação de lance por rodada
MIN_DATA_IMPRESSIONS=200       # Mínimo de impressões para tomar decisão
MIN_DATA_CLICKS=10             # Mínimo de cliques para tomar decisão
MAX_ACTIONS_PER_RUN=15        # Máximo de ações por execução

# ─── Metas de performance ──────────────────────────────────────────────────────
TARGET_ROAS=3.0    # ROAS mínimo desejado
TARGET_CPA=50.0    # CPA máximo em reais
MAX_CPC=10.0       # CPC máximo aceitável
MIN_CTR=0.005      # CTR mínimo (0.5%)

# ─── Modo de operação ──────────────────────────────────────────────────────────
# DRY_RUN=true  → simula as ações (não executa nada real) ← COMECE AQUI
# DRY_RUN=false → executa as ações em produção
DRY_RUN=true
